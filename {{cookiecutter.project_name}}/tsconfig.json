{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "lib": ["ESNext", "DOM"],
        "moduleResolution": "Node",
        "strict": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "noEmit": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "skipLibCheck": true,
        "types": ["vite/client"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["./hyper/*"],
            "@layouts/*": ["./hyper/layouts/*"],
            "@pages/*": ["./hyper/pages/*"],
            "@routes/*": ["./hyper/routes/*"],
            "@shared/*": ["./hyper/shared/*"]
        }
    },
    "include": ["./**/*.ts", "./**/*.js", "./**/*.d.ts"]
}
